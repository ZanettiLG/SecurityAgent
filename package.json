{
  "name": "security-agent",
  "version": "0.1.0",
  "description": "Vigia — Agente de IA para Segurança Doméstica com Inteligência Ambiental Contínua",
  "type": "module",
  "main": "dist/core/agent.js",
  "scripts": {
    "dev": "concurrently --names \"backend,dashboard\" --prefix-colors \"cyan,yellow\" \"tsx watch src/core/agent.ts\" \"cd dashboard && npm run dev\"",
    "build": "tsc",
    "start": "node dist/core/agent.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "lint": "eslint src/"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "chromadb": "^3.5.0",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "ioredis": "^5.4.0",
    "onvif": "^0.8.1",
    "openai": "^4.50.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "sharp": "^0.35.2",
    "ws": "^8.21.0",
    "xml2js": "^0.6.2",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.18.1",
    "concurrently": "^10.0.3",
    "eslint": "^9.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.62.1",
    "vitest": "^2.0.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "mqtt": "^5.6.0",
    "ollama": "^0.5.0",
    "pg": "^8.12.0"
  },
  "engines": {
    "node": ">=20"
  }
}
