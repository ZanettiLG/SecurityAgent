# ── Cameras ──
# Externa: 192.168.3.106 | Paths testados: /h264/ch1/main/av_stream (Hikvision),
#   /cam/realmonitor?channel=1&subtype=0 (Dahua), /stream1, /onvif1
# Se a URL abaixo nao funcionar, tente outro path do discovery acima
CAM1_USER=admin
CAM1_PASS=suasenha

# Interna: 192.168.3.65 | Paths testados: /h264Preview_01_main (Reolink),
#   /Streaming/Channels/101 (Hikvision), /stream2
# Se a URL abaixo nao funcionar, tente outro path do discovery acima
CAM2_USER=admin
CAM2_PASS=suasenha

# ── LLM ──
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Dashboard ──
# Porta do servidor HTTP/WebSocket do dashboard (default: 5174)
# Se a porta estiver ocupada, o servidor tenta automaticamente as próximas 10 portas
DASHBOARD_PORT=5174
# ── Opcionais ──
LOG_LEVEL=info
