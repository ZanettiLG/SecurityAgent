# ── Cameras ──
# Externa (Intelbras iM7 Full Color): 192.168.3.106
# Path: /cam/realmonitor?channel=1&subtype=0 (Intelbras/Dahua)
# Alternativos: /h264/ch1/main/av_stream (Hikvision), /stream1, /onvif1
CAM1_USER=admin
CAM1_PASS=suasenha
CAM1_IP=192.168.3.106
CAM1_PORT=554

# Interna (Yoosee): 192.168.3.65
# Path: /1 (Yoosee padrao) — usa UDP, nao TCP
# Alternativos: /0, /live/1, /h264Preview_01_main (Reolink), /Streaming/Channels/101 (Hikvision)
CAM2_USER=admin
CAM2_PASS=suasenha
CAM2_IP=192.168.3.65
CAM2_PORT=554
CAM2_PATH=/1

# ── LLM ──
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Opcionais ──
LOG_LEVEL=info
